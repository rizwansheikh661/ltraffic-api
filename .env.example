# ─── Runtime ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
API_PREFIX=/api/v1

# ─── Database (shared with PHP web — do NOT change schema of legacy tables) ──
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_NAME=lt_employee
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT_MS=10000

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=60d
BCRYPT_COST=10

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:8081,http://localhost:3000

# ─── Rate limiting ──────────────────────────────────────────
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# ─── File uploads (SHARED WITH PHP WEB — same folder as employeesarea/) ───
# Production: absolute path to the PHP web document root
#   e.g. UPLOADS_ROOT=C:\Inetpub\vhosts\ltraffic.co.uk\httpdocs\employeesarea
# Dev: keep the fallback so local runs write into ./dev-files/ instead of prod
UPLOADS_ROOT=./dev-files
# Public URL Apache/IIS serves UPLOADS_ROOT from (prod only). Blank = use PUBLIC_BASE_URL.
FILES_BASE_URL=
UPLOAD_MAX_MB=25

# ─── Firebase (leave blank until service-account JSON supplied) ──
FCM_ENABLED=false
FCM_SERVICE_ACCOUNT_PATH=

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_FILES=14d
